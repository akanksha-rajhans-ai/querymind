# QueryMind MVP runs locally without API keys.
# Future LLM provider integration can use these values.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
QUERYMIND_DB_PATH=data/querymind_demo.sqlite
QUERYMIND_HOST=127.0.0.1
QUERYMIND_PORT=8000
GEMINI_API_KEY=YOUR_API_KEY
QUERYMIND_GEMINI_MODEL=gemini-2.5-flash
QUERYMIND_USE_LLM=true


